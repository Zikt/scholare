# ── API Keys ─────────────────────────────────────────
# Get your SerpAPI key at: https://serpapi.com (100 free searches/month)
SERP_API_KEY=your_serpapi_key_here

# Get your Semantic Scholar key at: https://www.semanticscholar.org/product/api
# Optional but recommended — without it you're limited to 1 req/sec
S2_API_KEY=your_semantic_scholar_key_here

